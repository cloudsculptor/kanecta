{
  "name": "@kanecta/tiling-wm",
  "version": "1.4.0",
  "private": true,
  "description": "Control a running i3 / Sway tiling window manager over its IPC socket (Linux only). Zero runtime dependencies.",
  "main": "src/index.ts",
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "example:list": "node --import tsx examples/list-windows.ts",
    "example:move": "node --import tsx examples/move-resize.ts"
  },
  "devDependencies": {
    "tsx": "^4.23.0"
  },
  "engines": {
    "node": ">=18"
  },
  "os": [
    "linux"
  ],
  "license": "MIT"
}
