{
  "name": "@kanecta/transcript-import",
  "version": "1.4.0",
  "description": "Deterministic, idempotent importer for Claude Code session transcripts into a Kanecta datastore",
  "main": "src/index.ts",
  "bin": {
    "kanecta-import-transcripts": "bin/kanecta-import-transcripts.ts"
  },
  "files": [
    "src/",
    "bin/"
  ],
  "scripts": {
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "kanecta",
    "claude",
    "transcript",
    "ingestion"
  ],
  "author": "Kanecta",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kanecta/lib": "^1.0.0"
  },
  "devDependencies": {
    "@kanecta/postgres": "^1.4.0",
    "pg": "^8.22.0",
    "tsx": "^4.23.0"
  }
}
