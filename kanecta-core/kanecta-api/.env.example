# Where datastore data lives
KANECTA_DATASTORE=~/.kanecta

# Port the API server listens on (default: 3001)
PORT=3001

# Keycloak realm that issues access tokens — required unless AUTH_DISABLED=true.
# There is no default: every deployment provides its own Keycloak instance.
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=my-realm

# Set to "true" to bypass token verification for local development.
# Every request is treated as an authenticated local admin. Never use in production.
AUTH_DISABLED=false
