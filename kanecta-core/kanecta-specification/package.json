{
  "name": "@kanecta/specification",
  "version": "1.4.0",
  "description": "Kanecta datastore file format specifications and JSON schemas",
  "main": "index.ts",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./validator": "./1.4.0/kanecta-schema-validator/index.ts",
    "./1.4.0/validator": "./1.4.0/kanecta-schema-validator/index.ts",
    "./1.3.0/validator": "./1.3.0/kanecta-schema-validator/index.ts",
    "./1.2.0/*": "./1.2.0/*",
    "./1.3.0/*": "./1.3.0/*",
    "./1.4.0/*": "./1.4.0/*"
  },
  "files": [
    "index.ts",
    "1.2.0/",
    "1.3.0/",
    "1.4.0/"
  ],
  "scripts": {
    "build:spec": "asciidoctor 1.4.0/specification.adoc -o 1.4.0/specification.html",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "asciidoctor": "^4.0.5"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
