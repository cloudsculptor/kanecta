  "payload": {
    "meta": {
      "description": "A per-item expand override within a document. A document's expandState.exceptions map (item UUID → depth or false) is stored as `document-expand-exception` children of the document item, not an inline object.",
      "confidence": "locked",
      "icon": "UnfoldLess"
    },
    "jsonSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "documentExpandExceptionPayload",
      "type": "object",
      "required": [
        "overrideItemId",
        "depth"
      ],
      "additionalProperties": false,
      "properties": {
        "overrideItemId": {
          "type": "string",
          "format": "uuid",
          "x-kanecta-itemType": "item",
          "description": "UUID of the item this expand override applies to. (Named overrideItemId, not itemId, because itemId would snake-case to item_id and collide with the projection's primary-key column.)"
        },
        "depth": {
          "type": "integer",
          "minimum": -1,
          "description": "Expand depth for this item's subtree. -1 encodes 'collapse' (the false value in the source map); 0+ is an explicit depth."
        }
      }
    },
    "sqlSchema": [
      "-- Built-in type: adapter handles storage natively."
    ]
  }
