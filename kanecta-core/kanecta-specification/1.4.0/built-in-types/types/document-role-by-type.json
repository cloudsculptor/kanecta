  "payload": {
    "meta": {
      "description": "A type→role mapping entry within a document. A document's roleMap.byType map (item type name OR typeId UUID → role name) is stored as `document-role-by-type` children of the document item, not an inline object. The key is a plain string so both forms (type name and typeId UUID) round-trip losslessly; it is NOT a uuid reference.",
      "confidence": "locked",
      "icon": "Category"
    },
    "jsonSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "documentRoleByTypePayload",
      "type": "object",
      "required": [
        "key",
        "role"
      ],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "description": "Item type name (e.g. 'note') or a typeId UUID. UUID-keyed entries take precedence over byDepth. Stored as a plain string — not a uuid reference — so type-name keys are preserved."
        },
        "role": {
          "type": "string",
          "enum": [
            "title",
            "heading",
            "subheading",
            "body",
            "caption",
            "list-item",
            "code-block",
            "ignore"
          ],
          "description": "Document role assigned to items of this type."
        }
      }
    },
    "sqlSchema": [
      "-- Built-in type: adapter handles storage natively."
    ]
  }
}
