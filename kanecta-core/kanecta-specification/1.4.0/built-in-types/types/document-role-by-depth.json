    "meta": {
      "description": "A depth→role mapping entry within a document. A document's roleMap.byDepth map (depth integer → role name) is stored as `document-role-by-depth` children of the document item, not an inline object.",
      "confidence": "locked",
      "icon": "FormatListNumbered"
    },
    "jsonSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "documentRoleByDepthPayload",
      "type": "object",
      "required": [
        "depth",
        "role"
      ],
      "additionalProperties": false,
      "properties": {
        "depth": {
          "type": "integer",
          "minimum": 0,
          "description": "Depth below targetId (0 = targetId itself)."
        },
        "role": {
          "type": "string",
          "enum": [
            "title",
            "heading",
            "subheading",
            "body",
            "caption",
            "list-item",
            "code-block",
            "ignore"
          ],
          "description": "Document role assigned to items at this depth."
        }
      }
    },
