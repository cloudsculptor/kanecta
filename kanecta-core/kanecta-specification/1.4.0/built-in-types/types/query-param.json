      "description": "A named, typed parameter of a query. A query's parameters are query-param children of the query item (one per {{params.name}} placeholder), not an inline array.",
      "confidence": "locked",
      "icon": "Tune"
    },
    "jsonSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "queryParamPayload",
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Parameter name, referenced in the query expression as {{params.name}}. Unique among the query's params."
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "boolean",
            "uuid",
            "date"
          ],
          "description": "Parameter type — drives validation and Studio input-form generation."
        },
        "description": {
          "type": ["string", "null"],
          "description": "Human-readable explanation shown as the input-form label."
        },
        "defaultValue": {
          "type": ["string", "null"],
          "description": "Default value (text form, interpreted per `type`) used when the parameter is not supplied. Null means the parameter is required."
        }
      }
    },
    "sqlSchema": [
