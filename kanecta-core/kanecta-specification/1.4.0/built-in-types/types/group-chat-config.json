  "payload": {
    "meta": {
      "description": "Runtime config for a group-chat agent (multi-agent deliberation).",
      "confidence": "locked",
      "icon": "Groups"
    },
    "jsonSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "groupChatConfigPayload",
      "type": "object",
      "required": [
        "participants"
      ],
      "additionalProperties": false,
      "properties": {
        "participants": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "uuid",
            "x-kanecta-itemType": "agent"
          },
          "minItems": 1,
          "description": "UUIDs of the agent items that participate, in round-robin order."
        },
        "maxTurns": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Hard cap on total turns across all participants. Default 10."
        },
        "terminationCondition": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "explicit",
            "max-turns",
            null
          ],
          "description": "How the conversation ends: 'explicit' (a participant calls kanecta_conclude_discussion) or 'max-turns'."
        },
        "outputAgent": {
          "type": [
            "string",
            "null"
          ],
          "format": "uuid",
          "x-kanecta-itemType": "agent",
          "description": "UUID of the agent re-invoked to synthesise final items after 'max-turns' termination. Null for 'explicit'."
        }
      }
    },
    "sqlSchema": [
      "-- Built-in type: adapter handles storage natively."
    ]
