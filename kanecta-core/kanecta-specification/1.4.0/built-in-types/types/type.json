  "payload": {
    "meta": {
      "description": "A custom type definition \u2014 the meta-type.",
      "confidence": "locked"
    },
    "jsonSchema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "typePayload",
      "type": "object",
      "required": [
        "meta",
        "jsonSchema",
        "sqlSchema"
      ],
      "additionalProperties": false,
      "properties": {
        "meta": {
          "type": "object",
          "required": [
            "description"
          ],
          "additionalProperties": false,
          "properties": {
            "icon": {
              "type": "string",
              "description": "MUI icon component name (e.g. \"Person\")."
            },
            "description": {
              "type": "string",
              "description": "One-sentence summary (required)."
            },
            "details": {
              "type": "string",
              "description": "Longer description."
            },
            "keywords": {
              "type": "string",
              "description": "Space-separated search keywords."
            },
            "tags": {
              "type": "string",
              "description": "Comma-separated grouping tags."
            },
            "aliasFormulas": {
              "type": "object",
              "additionalProperties": {
                "type": "string",
                "format": "uuid"
              },
              "description": "Map of named formula references for alias auto-generation. Keys are scope names (\"default\" is conventional); values are UUIDs of formula items."
            },
            "primaryField": {
              "description": "The field or expression that computes item.value for instances. Three forms: plain string path (\"name\"), object with fields array + optional expression, or object with fields + functionId.",
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "required": [
                    "fields"
                  ],
                  "properties": {
                    "fields": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "expression": {
                      "type": "string"
                    },
                    "functionId": {
                      "type": "string",
                      "format": "uuid"
                    }
                  }
                }
              ]
            },
            "searchFields": {
              "type": [
                "array",
                "null"
              ],
              "items": {
                "type": "string"
              },
              "description": "Payload field names to include in the FTS corpus. Null = all fields."
            },
            "componentId": {
              "type": [
                "string",
                "null"
              ],
              "format": "uuid",
              "description": "UUID of a Kanecta component item that renders instances of this type in any context. Used when no defaultViews entry matches the current context. Null means fall through to the built-in generic renderer."
            },
            "defaultViews": {
              "type": [
                "array",
                "null"
              ],
              "description": "Ordered array of context-specific component bindings. Studio checks these in order during view resolution, using the first entry whose contextId matches the current context exactly. Allows a type to declare different renderers for different display positions (tree-node, detail-panel, modal, etc.) without requiring per-item view items for every instance. Null or empty means no context-specific defaults.",
              "items": {
                "type": "object",
                "required": [
                  "contextId",
                  "componentId"
                ],
                "additionalProperties": false,
                "properties": {
                  "contextId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "UUID of the context item this component binding applies to. Must match the current context exactly (both runtime and display)."
                  },
                  "componentId": {
                    "type": "string",
                    "format": "uuid",
                    "description": "UUID of the component item to use when this context matches."
                  }
                }
              }
            },
            "skills": {
              "type": "object",
              "properties": {
                "claude": {
                  "type": "string",
                  "description": "Guidance for Claude on when and how to use this type."
                }
              },
              "additionalProperties": false
            },
            "functions": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              },
              "description": "UUIDs of associated function items."
            },
            "sync": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              },
              "description": "UUIDs of function items that can refresh instances from an external source."
            },
            "supersededBy": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              },
              "description": "UUIDs of type definitions that replace this one."
            },
            "implements": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              },
              "description": "UUIDs of types whose contract this type fulfils (interface-style). Declared, not enforced by storage."
            },
            "extends": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uuid"
              },
              "description": "UUIDs of types this type extends or specialises. Declared relationship only \u2014 no storage inheritance."
            },
            "immutable": {
              "type": "boolean",
              "description": "When true, the type's contract is sealed."
            },
            "hash": {
              "type": "string",
              "description": "SHA-256 over jsonSchema + sqlSchema + primaryField. Computed and set when immutable is true."
            }
          }
        },
        "jsonSchema": {
          "type": "object",
          "description": "JSON Schema Draft-07 for instances. Types are flat \u2014 exactly one level deep. Each property must carry a stable x-id UUID."
        },
        "sqlSchema": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Ordered SQL DDL statements (PostgreSQL dialect) that create all storage for instances of this type."
        }
      }
    },
    "sqlSchema": [
      "-- Built-in type: adapter handles storage natively."
    ]
  }
