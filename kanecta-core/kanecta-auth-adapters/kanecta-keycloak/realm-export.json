{
  "realm": "kanecta-test",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full access"
      },
      {
        "name": "member",
        "description": "Standard member access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "kanecta-studio-test",
      "name": "Kanecta Studio (test)",
      "enabled": true,
      "publicClient": true,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:9743/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:9743",
        "http://localhost:5173"
      ],
      "defaultClientScopes": [
        "profile",
        "email",
        "kanecta-api"
      ]
    }
  ],
  "users": [
    {
      "username": "kanecta-admin",
      "email": "kanecta-admin@example.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Kanecta",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "kanecta-admin-password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "kanecta-member",
      "email": "kanecta-member@example.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Kanecta",
      "lastName": "Member",
      "credentials": [
        {
          "type": "password",
          "value": "kanecta-member-password",
          "temporary": false
        }
      ],
      "realmRoles": [
        "member"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "kanecta-api",
      "description": "Adds aud=kanecta-api to access tokens so kanecta-api can verify audience",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "kanecta-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "kanecta-api",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        }
      ]
    }
  ]
}