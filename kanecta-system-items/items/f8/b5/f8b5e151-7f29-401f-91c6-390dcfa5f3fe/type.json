  "jsonSchema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "repository",
    "title": "Repository",
    "type": "object",
    "required": [
      "name",
      "owner",
      "url"
    ],
    "properties": {
      "name": {
        "x-id": "8af37976-36c0-4be5-a814-e9837ff8807d",
        "type": "string",
        "description": "Repository name, e.g. landonline-admin-portal"
      },
      "owner": {
        "x-id": "cfabe907-449e-4646-8e3a-cbd1c65ff825",
        "type": "string",
        "description": "GitHub org or user, e.g. acme"
      },
      "url": {
        "x-id": "b1f6adf9-4204-4a6b-97fd-c611ff87b1e4",
        "type": "string",
        "format": "uri",
        "description": "Full GitHub URL"
      },
      "description": {
        "x-id": "195ebef0-f371-48b4-84c2-0962f9441755",
        "type": "string"
      },
      "visibility": {
        "x-id": "af1fff2f-264b-4491-b928-2e2f30ae889f",
        "type": "string",
        "enum": [
          "public",
          "private",
          "internal"
        ]
      },
      "defaultBranch": {
        "x-id": "2b192ba1-82bd-45c1-87b9-806681300218",
        "type": "string",
        "default": "main"
      },
      "language": {
        "x-id": "f94877e5-8898-4407-814a-78ca60e73d85",
        "type": "string",
        "description": "Primary language, e.g. Kotlin, TypeScript"
      },
      "topics": {
        "x-id": "c666a2c1-f1ed-478d-a0e9-a70a145efb38",
        "type": "array",
        "items": {
          "type": "string"
        },
        "uniqueItems": true
      },
      "archived": {
        "x-id": "2d6ca19f-5218-4df7-89df-33525be4fed3",
        "type": "boolean",
        "default": false
      },
      "relatedServices": {
        "x-id": "61d22cdf-9f45-4ab0-8ec5-456db76b7d34",
        "type": "array",
        "items": {
          "type": "string"
        },
        "uniqueItems": true,
        "description": "Names of other repos/services this one depends on or integrates with"
      },
      "codeowners": {
        "x-id": "467a0327-ce16-4bf4-b714-982887464023",
        "type": "array",
        "items": {
          "type": "string"
        },
        "uniqueItems": true
      },
      "packageManager": {
        "x-id": "20b8f6ea-722e-4bd8-80df-10528463037d",
        "type": "string",
        "enum": [
          "npm",
          "yarn",
          "pnpm",
          "gradle",
          "maven",
          "pip",
          "cargo",
          "go"
        ]
      },
      "cloneUrl": {
        "x-id": "4953c459-0e87-427d-8582-0230eb31f01e",
        "type": "string",
        "format": "uri"
      },
      "stackFrontend": {
        "x-id": "70a6f74e-b15d-46b4-bec4-ff7bd7ccb1e9",
        "type": "string",
        "description": "Frontend technology stack."
      },
      "stackBackend": {
        "x-id": "5312452b-e647-4c49-96ce-70ede7307ae4",
        "type": "string",
        "description": "Backend technology stack."
      },
      "stackInfrastructure": {
        "x-id": "e8fd0743-2034-409e-812a-8c0d1ce5af67",
        "type": "string",
        "description": "Infrastructure stack."
      },
      "stackCiCd": {
        "x-id": "fa9ca496-45b6-4f66-ab80-58475c3989de",
        "type": "string",
        "description": "CI/CD tooling."
      }
    }
  },
  "sqlSchema": [
    "CREATE TABLE \"obj_f8b5e151_7f29_401f_91c6_390dcfa5f3fe\" (\n    item_id UUID NOT NULL,\n    \"name\" TEXT,\n    \"owner\" TEXT,\n    \"url\" TEXT,\n    \"description\" TEXT,\n    \"visibility\" TEXT,\n    \"default_branch\" TEXT,\n    \"language\" TEXT,\n    \"topics\" TEXT[] NOT NULL DEFAULT '{}',\n    \"archived\" BOOLEAN,\n    \"related_services\" TEXT[] NOT NULL DEFAULT '{}',\n    \"codeowners\" TEXT[] NOT NULL DEFAULT '{}',\n    \"package_manager\" TEXT,\n    \"clone_url\" TEXT,\n    \"stack_frontend\" TEXT,\n    \"stack_backend\" TEXT,\n    \"stack_infrastructure\" TEXT,\n    \"stack_ci_cd\" TEXT,\n    CONSTRAINT \"pk_obj_f8b5e151_7f29_401f_91c6_390dcfa5f3fe\" PRIMARY KEY (item_id),\n    CONSTRAINT \"fk_f8b5e1517f29401f_item\" FOREIGN KEY (item_id) REFERENCES items(id)\n)"
  ]
}
