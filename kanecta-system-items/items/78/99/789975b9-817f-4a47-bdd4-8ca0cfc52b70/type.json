{
  "meta": {
    "icon": "DescriptionOutlined",
    "description": "Self-describing specification for a Kanecta pipeline — purpose, philosophy, step contracts, learning loops and planned integrations",
    "keywords": "pipeline spec about description steps learning loops integrations",
    "tags": "pipeline,documentation",
    "ai-instructions": {
      "claude": "A Pipeline Spec is the 'about' document for a pipeline. It describes purpose, philosophy, each step's input/output contract, the improvement loops, and planned integrations. Referenced by the Pipeline item's 'about' field. Can be tagged org-context to inject pipeline knowledge into AI reasoning."
    }
  },
  "jsonSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "pipeline-spec",
    "title": "Pipeline Spec",
    "type": "object",
    "required": [
      "purpose"
    ],
    "additionalProperties": false,
    "properties": {
      "purpose": {
        "type": "string"
      },
      "philosophy": {
        "type": "string"
      },
      "version": {
        "type": "string"
      },
      "inputType": {
        "type": "string",
        "description": "Human-readable name or UUID of the primary input type"
      },
      "outputType": {
        "type": "string",
        "description": "Human-readable name or UUID of the primary output type"
      },
      "steps": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "name",
            "status"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "consumes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "produces": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "status": {
              "type": "string",
              "enum": [
                "active",
                "disabled",
                "placeholder",
                "side-branch"
              ]
            },
            "loopsTo": {
              "type": "string",
              "description": "Step name this step loops back to"
            }
          }
        }
      },
      "learningLoops": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "name",
            "type"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "internal",
                "external"
              ]
            },
            "effect": {
              "type": "string",
              "enum": [
                "permanent",
                "run-scoped"
              ]
            },
            "status": {
              "type": "string",
              "enum": [
                "active",
                "placeholder"
              ]
            }
          }
        }
      },
      "integrations": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "name",
            "status"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "contributes": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "active",
                "planned",
                "in-progress"
              ]
            }
          }
        }
      }
    }
  }
}