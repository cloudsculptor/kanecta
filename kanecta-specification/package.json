{
  "name": "@kanecta/specification",
  "version": "1.3.0",
  "description": "Kanecta datastore file format specifications and JSON schemas",
  "main": "index.js",
  "module": "index.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "types": "./index.d.ts"
    },
    "./validator": {
      "import": "./1.3.0/kanecta-schema-validator/index.mjs",
      "require": "./1.3.0/kanecta-schema-validator/index.js",
      "types": "./1.3.0/kanecta-schema-validator/index.d.ts"
    },
    "./1.3.0/validator": {
      "import": "./1.3.0/kanecta-schema-validator/index.mjs",
      "require": "./1.3.0/kanecta-schema-validator/index.js",
      "types": "./1.3.0/kanecta-schema-validator/index.d.ts"
    },
    "./1.2.0/*": "./1.2.0/*",
    "./1.3.0/*": "./1.3.0/*"
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "1.2.0/",
    "1.3.0/"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
