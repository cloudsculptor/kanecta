{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kanecta.org/specification/kanecta-meta-v1",
  "title": "Kanecta Item Display Cache",
  "description": "Schema for a Kanecta meta.json file. Stored at .kanecta/data/{shard1}/{shard2}/{uuid}/meta.json for typed object items only. Written when an item of type 'object' is created or its typeId changes. Contains a denormalized copy of the type definition's metadata.json, with 'type' overridden to 'object' and 'icon' added from the type's type.json meta. Used for fast display without needing to look up the type definition on every read.",
  "type": "object",
  "required": ["id", "parentId", "value", "type", "owner", "createdAt", "modifiedAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID of the type definition this item belongs to."
    },
    "parentId": {
      "type": ["string", "null"],
      "description": "parentId from the type definition's metadata."
    },
    "value": {
      "type": ["string", "null"],
      "description": "Name of the type (e.g. 'Person', 'Place')."
    },
    "type": {
      "type": "string",
      "const": "object",
      "description": "Always 'object' — overrides the type definition record's own 'type' field ('type')."
    },
    "typeId": {
      "type": ["string", "null"],
      "description": "Always null for type definition records."
    },
    "icon": {
      "type": ["string", "null"],
      "description": "MUI icon component name sourced from type.json meta.icon. Present only when the type definition has an icon set."
    },
    "owner": {
      "type": "string",
      "description": "Owner identifier from the type definition's metadata."
    },
    "license": {
      "type": ["string", "null"]
    },
    "sortOrder": {
      "type": ["number", "null"]
    },
    "confidence": {
      "type": ["string", "null"],
      "enum": [null, "experimental", "exploring", "decided", "locked", "low", "medium", "high", "verified"]
    },
    "status": {
      "type": ["string", "null"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "modifiedAt": {
      "type": "string",
      "format": "date-time"
    },
    "createdBy": {
      "type": ["string", "null"]
    },
    "modifiedBy": {
      "type": ["string", "null"]
    },
    "cachedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "subscribedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "subscriptionSource": {
      "type": ["string", "null"]
    }
  },
  "examples": [
    {
      "id": "f1e2d3c4-b5a6-7890-abcd-ef1234567890",
      "parentId": null,
      "value": "Person",
      "type": "object",
      "typeId": null,
      "icon": "Person",
      "owner": "richardsempire@gmail.com",
      "license": null,
      "sortOrder": null,
      "confidence": null,
      "status": null,
      "tags": [],
      "createdAt": "2025-01-01T00:00:00.000Z",
      "modifiedAt": "2025-01-01T00:00:00.000Z",
      "createdBy": "richardsempire@gmail.com",
      "modifiedBy": "richardsempire@gmail.com",
      "cachedAt": null,
      "subscribedAt": null,
      "subscriptionSource": null
    }
  ]
}
