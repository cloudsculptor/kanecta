{
  "name": "@kanecta/ui-specification",
  "version": "1.4.0",
  "description": "Kanecta UI layer specification and validator for component packages and app manifests",
  "main": "index.ts",
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./validator": "./1.4.0/kanecta-ui-validator/index.ts",
    "./1.4.0/validator": "./1.4.0/kanecta-ui-validator/index.ts",
    "./1.4.0/*": "./1.4.0/*"
  },
  "scripts": {
    "build:spec": "asciidoctor 1.4.0/specification.adoc -o 1.4.0/specification.html",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "asciidoctor": "^4.0.5"
  },
  "files": [
    "index.ts",
    "1.4.0/"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
