{
  "name": "kanecta-studio-mac",
  "version": "1.4.0",
  "private": true,
  "description": "Desktop wrapper for Kanecta Studio, packaged as a macOS app",
  "main": "main.cjs",
  "author": {
    "name": "Kanecta",
    "email": "richardsempire@gmail.com"
  },
  "homepage": "https://github.com/cloudsculptor/kanecta",
  "scripts": {
    "build": "esbuild main.ts --platform=node --format=cjs --target=node20 --outfile=main.cjs",
    "prestart": "npm run build",
    "start": "electron .",
    "predist": "npm run build",
    "dist": "electron-builder --mac zip"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "electron": "43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1"
  },
  "license": "MIT",
  "build": {
    "appId": "com.kanecta.studio",
    "productName": "Kanecta Studio",
    "files": [
      "main.cjs"
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity",
      "identity": null
    }
  }
}
