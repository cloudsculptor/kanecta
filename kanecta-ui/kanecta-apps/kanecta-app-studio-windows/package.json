{
  "name": "kanecta-studio-windows",
  "version": "1.4.0",
  "private": true,
  "description": "Desktop wrapper for Kanecta Studio, packaged as a Windows installer",
  "main": "main.cjs",
  "author": {
    "name": "Kanecta",
    "email": "richardsempire@gmail.com"
  },
  "homepage": "https://github.com/cloudsculptor/kanecta",
  "scripts": {
    "build": "esbuild main.ts --platform=node --format=cjs --target=node20 --outfile=main.cjs",
    "prestart": "npm run build",
    "start": "electron .",
    "predist": "npm run build",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "43.0.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.1"
  },
  "license": "MIT",
  "build": {
    "appId": "com.kanecta.studio",
    "productName": "Kanecta Studio",
    "files": [
      "main.cjs"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "signExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
