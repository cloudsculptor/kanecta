# Primary Kanecta API endpoint (dev server proxy target)
KANECTA_API_URL=http://localhost:3001

# Keycloak instance to authenticate against — required unless VITE_AUTH_DISABLED=true.
# There is no default: every deployment provides its own Keycloak instance.
VITE_KEYCLOAK_URL=https://keycloak.example.com
VITE_KEYCLOAK_REALM=my-realm
VITE_KEYCLOAK_CLIENT_ID=kanecta

# Set to "true" to skip Keycloak entirely for local development.
# No login screen, no account menu, no Authorization header sent.
# Pair with the API's AUTH_DISABLED=true. Never use in production.
VITE_AUTH_DISABLED=false
