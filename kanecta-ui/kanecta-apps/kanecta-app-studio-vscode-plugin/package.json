{
  "name": "kanecta-studio-vscode",
  "displayName": "Kanecta Studio",
  "description": "Open Kanecta Studio inside VS Code, wrapping the Studio frontend in a webview",
  "version": "1.4.0",
  "private": true,
  "publisher": "kanecta",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudsculptor/kanecta"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "build/icon.png",
  "main": "./extension.js",
  "files": [
    "extension.js",
    "build/icon.png",
    "README.md",
    "LICENSE"
  ],
  "contributes": {
    "commands": [
      {
        "command": "kanecta-studio.open",
        "title": "Open Kanecta Studio",
        "category": "Kanecta"
      }
    ]
  },
  "scripts": {
    "build": "esbuild extension.ts --bundle --platform=node --format=cjs --target=node20 --external:vscode --outfile=extension.js",
    "vscode:prepublish": "npm run build",
    "prepackage": "npm run build",
    "package": "vsce package --out dist --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1"
  },
  "license": "MIT"
}
