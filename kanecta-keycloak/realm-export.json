{
  "realm": "kanecta-test",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Full access" },
      { "name": "member", "description": "Standard member access" }
    ]
  },
  "clients": [
    {
      "clientId": "kanecta-studio-test",
      "name": "Kanecta Studio (test)",
      "enabled": true,
      "publicClient": true,
