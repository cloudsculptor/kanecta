      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["http://localhost:9743/*", "http://localhost:5173/*"],
      "webOrigins": ["http://localhost:9743", "http://localhost:5173"]
    }
  ],
  "users": [
    {
      "username": "kanecta-admin",
      "email": "kanecta-admin@example.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Kanecta",
      "lastName": "Admin",
      "credentials": [
        { "type": "password", "value": "kanecta-admin-password", "temporary": false }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "kanecta-member",
      "email": "kanecta-member@example.com",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Kanecta",
      "lastName": "Member",
      "credentials": [
        { "type": "password", "value": "kanecta-member-password", "temporary": false }
      ],
      "realmRoles": ["member"]
    }
  ]
